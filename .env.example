# ===========================================
# Research7 Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values.

# --- Required Variables ---

# OpenAI API key for generating text embeddings
OPENAI_API_KEY=your-openai-api-key

# Zilliz Cloud (managed Milvus) connection URI
ZILLIZ_CLOUD_URI=https://your-instance.zillizcloud.com

# Zilliz Cloud API token for authentication
ZILLIZ_CLOUD_TOKEN=your-zilliz-cloud-token

# AWS region where the Lambda function is deployed
AWS_REGION=us-east-1

# Name of the AWS Lambda function for embedding generation
AWS_LAMBDA_FUNCTION_NAME=your-lambda-function-name

# --- Optional Variables ---

# Semantic Scholar API key (optional — provides higher rate limits)
# SEMANTIC_SCHOLAR_API_KEY=your-semantic-scholar-api-key
