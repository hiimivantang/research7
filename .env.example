# =============================================================================
# Research7 Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# All variables marked [REQUIRED] must be set for the application to start.
# =============================================================================

# [REQUIRED] OpenAI API key for generating text embeddings
OPENAI_API_KEY=

# [REQUIRED] Zilliz Cloud cluster connection URI
ZILLIZ_CLOUD_URI=

# [REQUIRED] Zilliz Cloud API token for authentication
ZILLIZ_CLOUD_TOKEN=

# [REQUIRED] AWS region where the Lambda function is deployed (e.g., us-east-1)
AWS_REGION=

# [REQUIRED] Name of the AWS Lambda function for embedding generation
AWS_LAMBDA_FUNCTION_NAME=

# [OPTIONAL] Semantic Scholar API key — provides higher rate limits
# Sign up at https://www.semanticscholar.org/product/api to obtain one.
# The service works without this key but may be rate-limited.
SEMANTIC_SCHOLAR_API_KEY=
